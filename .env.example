# Database
DB_HOST=your-db-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_PORT=24231

# OTP email delivery for all users
# Brevo is recommended here because Resend's onboarding sender only sends to verified test recipients.
EMAIL_PROVIDER=brevo
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_PASS=your-brevo-smtp-key
BREVO_FROM=Loan App <verified-sender@example.com>

# Optional Gmail fallback. Use a Gmail app password, not your normal Gmail password.
# EMAIL_PROVIDER=gmail
# EMAIL_USER=your-address@gmail.com
# EMAIL_PASS=your-gmail-app-password
# EMAIL_FROM=Loan App <your-address@gmail.com>

# Optional Resend. Must use a verified sender/domain, not onboarding@resend.dev.
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key
# EMAIL_FROM=Loan App <verified-sender@example.com>

# OTP expiration windows
RESET_CODE_TTL_MINUTES=15
RESET_VERIFIED_TTL_MINUTES=10

# M-Pesa
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
BACKEND_URL=https://your-backend-url

# Admin
ADMIN_SECRET=change-this-admin-secret
